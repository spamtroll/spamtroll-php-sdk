{
    "name": "spamtroll/php-sdk",
    "description": "PHP SDK for the Spamtroll spam detection API.",
    "type": "library",
    "license": "MIT",
    "keywords": ["spamtroll", "spam", "anti-spam", "sdk", "api"],
    "homepage": "https://spamtroll.io",
    "support": {
        "source": "https://github.com/spamtroll/php-sdk",
        "issues": "https://github.com/spamtroll/php-sdk/issues"
    },
    "require": {
        "php": ">=8.0",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.58",
        "peckphp/peck": "^0.1",
        "pestphp/pest": "^2.34",
        "pestphp/pest-plugin-arch": "^2.7",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^1.11",
        "phpstan/phpstan-strict-rules": "^1.6",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Spamtroll\\Sdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Spamtroll\\Sdk\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        },
        "platform": {
            "php": "8.3"
        },
        "sort-packages": true
    },
    "scripts": {
        "test": "pest",
        "test:coverage": "pest --coverage",
        "lint": "php-cs-fixer fix --dry-run --diff",
        "lint:fix": "php-cs-fixer fix",
        "stan": "phpstan analyse --memory-limit=512M",
        "peck": "peck",
        "qa": [
            "@lint",
            "@stan",
            "@peck",
            "@test"
        ]
    },
    "scripts-descriptions": {
        "test": "Run the Pest test suite",
        "test:coverage": "Run tests with coverage report",
        "lint": "Check code style without modifying files",
        "lint:fix": "Auto-format code to match code style",
        "stan": "Run PHPStan static analysis",
        "peck": "Run the peck spell checker over identifiers and docblocks",
        "qa": "Full quality gate: lint check, static analysis, spell-check, and tests"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
